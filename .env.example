# openai
OPENAI_API_KEY=OPENAI_API_KEY

# Optional: point the LLM calls at any OpenAI-compatible endpoint
# (local model server, Azure, a proxy/gateway, etc.).
# Applies to BOTH the /generate-ui engine and the /chat/stream agent.
# Leave unset/commented to use the default OpenAI API.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: model id used for all pipeline stages (default: gpt-5).
# Must be a model your endpoint above actually serves.
# OGEN_MODEL=gpt-5

# Langsmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=LANGSMITH_API_KEY
LANGSMITH_PROJECT=LANGSMITH_PROJECT