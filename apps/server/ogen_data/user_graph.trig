	<http://ogen.ai/ontology/required> true ;
	<http://ogen.ai/ontology/validationRules> "{\"minLength\":8,\"message\":\"비밀번호는 최소 8자 이상이어야 합니다\"}" ;
	<http://ogen.ai/ontology/propType> "input[type='password']" ;
