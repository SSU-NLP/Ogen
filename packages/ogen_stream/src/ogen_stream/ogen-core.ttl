@prefix ex: <http://ogen.ai/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### 1. [Meta] 디자인 시스템 계층 구조 (Atomic Design) ###
ex:UIElement a rdfs:Class .

ex:Atom a rdfs:Class ; 
    rdfs:subClassOf ex:UIElement ;
    rdfs:comment "더 이상 쪼갤 수 없는 최소 단위 (버튼, 인풋, 아이콘)" .

ex:Molecule a rdfs:Class ; 
    rdfs:subClassOf ex:UIElement ;
    rdfs:comment "Atom들이 모여 하나의 기능을 하는 그룹 (검색바, 라벨이 있는 인풋)" .

ex:Organism a rdfs:Class ; 
    rdfs:subClassOf ex:UIElement ;
    rdfs:comment "서비스의 특정 섹션을 담당하는 독립적인 컨테이너 (로그인 카드, 헤더)" .

ex:Template a rdfs:Class ; 
    rdfs:subClassOf ex:UIElement ;
    rdfs:comment "페이지 레벨의 레이아웃 구조" .

### 2. [Properties] 컴포넌트 속성 정의 ###
ex:hasPart a rdf:Property ;
    rdfs:label "hasPart" ;
    rdfs:comment "컴포넌트가 포함하는 하위 컴포넌트들을 정의" ;
    rdfs:domain ex:UIElement ;
    rdfs:range ex:UIElement .

ex:propSchema a rdf:Property ;
    rdfs:label "propSchema" ;
    rdfs:comment "컴포넌트의 속성 스키마를 JSON 형식으로 정의" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:propType a rdf:Property ;
    rdfs:label "propType" ;
    rdfs:comment "컴포넌트의 기본 타입 (예: input[type='email'], button 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:keywords a rdf:Property ;
    rdfs:label "keywords" ;
    rdfs:comment "검색 보정용 키워드 (다국어 지원)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:stylePreset a rdf:Property ;
    rdfs:label "stylePreset" ;
    rdfs:comment "기본 스타일 프리셋 (CSS 형식)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

### 3. [Action] 컴포넌트 동작 정의 ###
ex:Action a rdfs:Class ;
    rdfs:subClassOf ex:UIElement ;
    rdfs:comment "사용자 상호작용을 처리하는 컴포넌트 (버튼, 링크 등)" .

ex:requires a rdf:Property ;
    rdfs:label "requires" ;
    rdfs:comment "이 컴포넌트가 필요로 하는 다른 컴포넌트" ;
    rdfs:domain ex:Action ;
    rdfs:range ex:UIElement .

### 4. [Container] 컨테이너 컴포넌트 정의 ###
ex:Container a rdfs:Class ;
    rdfs:subClassOf ex:UIElement ;
    rdfs:comment "다른 컴포넌트를 포함할 수 있는 컨테이너" .

### 5. [Layout Properties] 레이아웃 속성 정의 ###
ex:layoutType a rdf:Property ;
    rdfs:label "layoutType" ;
    rdfs:comment "레이아웃 타입 (flex, grid, block, inline 등)" ;
    rdfs:domain ex:Container ;
    rdfs:range xsd:string .

ex:flexDirection a rdf:Property ;
    rdfs:label "flexDirection" ;
    rdfs:comment "Flexbox 방향 (row, column 등)" ;
    rdfs:domain ex:Container ;
    rdfs:range xsd:string .

ex:spacing a rdf:Property ;
    rdfs:label "spacing" ;
    rdfs:comment "컴포넌트 간 간격 (CSS 값)" ;
    rdfs:domain ex:Container ;
    rdfs:range xsd:string .

ex:alignment a rdf:Property ;
    rdfs:label "alignment" ;
    rdfs:comment "정렬 방식 (start, center, end, stretch 등)" ;
    rdfs:domain ex:Container ;
    rdfs:range xsd:string .

### 6. [Validation Properties] 검증 속성 정의 ###
ex:validationRules a rdf:Property ;
    rdfs:label "validationRules" ;
    rdfs:comment "입력 검증 규칙 (JSON 형식)" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:string .

ex:required a rdf:Property ;
    rdfs:label "required" ;
    rdfs:comment "필수 입력 여부" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:boolean .

ex:minLength a rdf:Property ;
    rdfs:label "minLength" ;
    rdfs:comment "최소 길이 제한" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:integer .

ex:maxLength a rdf:Property ;
    rdfs:label "maxLength" ;
    rdfs:comment "최대 길이 제한" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:integer .

ex:pattern a rdf:Property ;
    rdfs:label "pattern" ;
    rdfs:comment "정규식 패턴" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:string .

### 7. [Event Properties] 이벤트 속성 정의 ###
ex:onClick a rdf:Property ;
    rdfs:label "onClick" ;
    rdfs:comment "클릭 이벤트 핸들러 (함수 이름 또는 설명)" ;
    rdfs:domain ex:Action ;
    rdfs:range xsd:string .

ex:onChange a rdf:Property ;
    rdfs:label "onChange" ;
    rdfs:comment "변경 이벤트 핸들러 (함수 이름 또는 설명)" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:string .

ex:onSubmit a rdf:Property ;
    rdfs:label "onSubmit" ;
    rdfs:comment "제출 이벤트 핸들러 (함수 이름 또는 설명)" ;
    rdfs:domain ex:Container ;
    rdfs:range xsd:string .

ex:onFocus a rdf:Property ;
    rdfs:label "onFocus" ;
    rdfs:comment "포커스 이벤트 핸들러" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:string .

ex:onBlur a rdf:Property ;
    rdfs:label "onBlur" ;
    rdfs:comment "블러 이벤트 핸들러" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:string .

### 8. [Accessibility Properties] 접근성 속성 정의 ###
ex:ariaLabel a rdf:Property ;
    rdfs:label "ariaLabel" ;
    rdfs:comment "접근성을 위한 라벨 (ARIA label)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:role a rdf:Property ;
    rdfs:label "role" ;
    rdfs:comment "ARIA role (button, textbox, form 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:ariaDescribedBy a rdf:Property ;
    rdfs:label "ariaDescribedBy" ;
    rdfs:comment "설명을 제공하는 요소의 ID" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:ariaRequired a rdf:Property ;
    rdfs:label "ariaRequired" ;
    rdfs:comment "ARIA required 속성" ;
    rdfs:domain ex:Atom ;
    rdfs:range xsd:boolean .

### 9. [State Properties] 상태 관리 속성 정의 ###
ex:state a rdf:Property ;
    rdfs:label "state" ;
    rdfs:comment "컴포넌트 상태 (loading, disabled, error, success 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:defaultState a rdf:Property ;
    rdfs:label "defaultState" ;
    rdfs:comment "기본 상태 (enabled, disabled 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:loadingState a rdf:Property ;
    rdfs:label "loadingState" ;
    rdfs:comment "로딩 상태 표시 여부" ;
    rdfs:domain ex:Action ;
    rdfs:range xsd:boolean .

ex:disabledState a rdf:Property ;
    rdfs:label "disabledState" ;
    rdfs:comment "비활성화 상태 여부" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:boolean .

### 10. [Dependency Properties] 의존성 관계 속성 정의 ###
ex:conflictsWith a rdf:Property ;
    rdfs:label "conflictsWith" ;
    rdfs:comment "이 컴포넌트와 충돌하는 다른 컴포넌트" ;
    rdfs:domain ex:UIElement ;
    rdfs:range ex:UIElement .

ex:recommends a rdf:Property ;
    rdfs:label "recommends" ;
    rdfs:comment "이 컴포넌트와 함께 사용하기를 권장하는 컴포넌트" ;
    rdfs:domain ex:UIElement ;
    rdfs:range ex:UIElement .

ex:dependsOn a rdf:Property ;
    rdfs:label "dependsOn" ;
    rdfs:comment "이 컴포넌트가 의존하는 다른 컴포넌트" ;
    rdfs:domain ex:UIElement ;
    rdfs:range ex:UIElement .

### 11. [Style Properties] 스타일 속성 확장 ###
ex:variant a rdf:Property ;
    rdfs:label "variant" ;
    rdfs:comment "컴포넌트 변형 (primary, secondary, danger 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:size a rdf:Property ;
    rdfs:label "size" ;
    rdfs:comment "컴포넌트 크기 (small, medium, large 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

ex:theme a rdf:Property ;
    rdfs:label "theme" ;
    rdfs:comment "테마 (light, dark 등)" ;
    rdfs:domain ex:UIElement ;
    rdfs:range xsd:string .

