{
  "name": "@ogen/design-studio",
  "version": "0.0.1",
  "description": "Design system management tool for Ogen UI - scan components, edit metadata, generate TTL",
  "type": "module",
  "license": "MIT",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./scanner": {
      "types": "./dist/scanner/index.d.ts",
      "default": "./dist/scanner/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "svelte": "./dist/editor/index.js",
      "default": "./dist/editor/index.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "default": "./dist/generator/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-package",
    "prepublishOnly": "npm run build",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "cytoscape": "^3.31.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^25.9.1",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ogen",
    "design-system",
    "svelte",
    "ontology",
    "ttl",
    "rdf"
  ]
}
